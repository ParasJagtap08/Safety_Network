// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String
  email     String     @unique
  password  String
  gender    Gender
  address   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  location  Location[]
  alert     Alert[]
}

model Alert {
  id         Int        @id @default(autoincrement())
  accessCode String     @default(uuid())
  User       User       @relation(fields: [userId], references: [id])
  userId     Int
  audio      Audio[]
  image      Image[]
  location   Location[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Audio {
  id        Int      @id @default(autoincrement())
  alertId   Int
  alert     Alert    @relation(fields: [alertId], references: [id])
  base64    String
  createdAt DateTime @default(now())
}

model Image {
  id        Int      @id @default(autoincrement())
  alertId   Int
  alert     Alert    @relation(fields: [alertId], references: [id])
  base64    String
  createdAt DateTime @default(now())
}

model Location {
  id        Int      @id @default(autoincrement())
  User      User     @relation(fields: [userId], references: [id])
  userId    Int
  isalert   Boolean  @default(false)
  alertId   Int?
  alert     Alert?   @relation(fields: [alertId], references: [id])
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
}

enum Gender {
  MALE
  FEMALE
  OTHER
}
