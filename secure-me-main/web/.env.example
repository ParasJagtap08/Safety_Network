# URL of the backend API (no trailing slash)
NEXT_PUBLIC_API_URL=https://your-api-domain.example.com

# Mappls Maps API key
NEXT_PUBLIC_MAPPLS_API_KEY=your-mappls-api-key-here

# Public download URL for the mobile app APK
NEXT_PUBLIC_APP_DOWNLOAD_URL=https://your-apk-download-url.example.com/app.apk
